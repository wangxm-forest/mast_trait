angio_mast <- paste0(round(100 * N_angio_mast/angio_n),
  "\\% (",
  N_angio_mast,
  "/",
  angio_n,
  ")"
)

gymno_n <- length(conifer$latbi)
N_gymno <- 64
N_gymno_mast <- sum(conifer$mastEvent == "1", na.rm = TRUE)
gymno_sum <- paste0(round(100 * gymno_n/N_gymno),
  "\\% (",
  gymno_n,
  "/",
  N_gymno,
  ")"
)
gymno_mast <- paste0(round(100 * N_gymno_mast/gymno_n),
  "\\% (",
  N_gymno_mast,
  "/",
  gymno_n,
  ")"
)

fix_unicode <- function(x) {
  x <- gsub("\u2212", "-", x)
  x <- gsub("–", "-", x)
  x <- gsub("—", "-", x)
  x <- gsub("%", "\\\\%", x)
  x <- gsub("\\balpha\\b", "$\\\\alpha$", x)
  x <- gsub("\\blambda\\b", "$\\\\lambda$", x)
  x
}

angio_results[] <- lapply(angio_results, function(x) {
  if (is.character(x))
    fix_unicode(x)
  else
    x
})

colnames(angio_results) <-
    fix_unicode(colnames(angio_results))

conifer_results[] <- lapply(conifer_results, function(x) {
  if (is.character(x))
    fix_unicode(x)
  else
    x
})

colnames(conifer_results) <-
    fix_unicode(colnames(conifer_results))

seed_results[] <- lapply(seed_results, function(x) {
  if (is.character(x))
    fix_unicode(x)
  else
    x
})

colnames(seed_results) <-
    fix_unicode(colnames(seed_results))


lambda[] <- lapply(lambda, function(x) {
  if (is.character(x))
    fix_unicode(x)
  else
    x
})

colnames(lambda) <-
    fix_unicode(colnames(lambda))

